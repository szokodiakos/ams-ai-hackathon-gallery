{
  "name": "ams-ai-hackathon-gallery",
  "version": "0.0.1",
  "private": true,
  "description": "AI Hackathon Gallery - built with spec-driven development",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "generate-thumbnails": "npx tsx scripts/generate-thumbnails.ts",
    "refresh-games": "npx tsx scripts/refresh-games.ts",
    "opsx:init": "openspec init --tools claude --profile core --force"
  },
  "dependencies": {
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@fission-ai/openspec": "latest",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
